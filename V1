<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Code-Realme-NonStoP - Portal</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Orbitron for Sci-Fi Gaming feel, Inter for text -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Orbitron:wght@500;700;900&display=swap" rel="stylesheet">
    <!-- Font Awesome for premium icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0b0214; /* Deep space purple black */
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(147, 51, 234, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(234, 179, 8, 0.08) 0%, transparent 50%);
            overflow-x: hidden;
        }

        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }

        /* Ambient glowing effects */
        .neon-glow-purple {
            box-shadow: 0 0 25px rgba(168, 85, 247, 0.25);
        }

        .neon-glow-gold {
            box-shadow: 0 0 25px rgba(234, 179, 8, 0.2);
        }

        /* Admin visual override */
        .admin-glow {
            border-color: #ef4444 !important;
            box-shadow: 0 0 30px rgba(239, 68, 68, 0.5), inset 0 0 15px rgba(239, 68, 68, 0.2) !important;
            background: rgba(30, 0, 10, 0.8) !important;
        }

        .admin-text-pulse {
            animation: red-gold-pulse 1.5s infinite alternate;
        }

        @keyframes red-gold-pulse {
            0% { text-shadow: 0 0 5px #ef4444; color: #f87171; }
            100% { text-shadow: 0 0 15px #eab308; color: #facc15; }
        }

        /* Gold and Purple border transitions */
        .btn-card {
            background: rgba(20, 10, 35, 0.6);
            backdrop-filter: blur(12px);
            border: 2px solid rgba(234, 179, 8, 0.3);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-card:hover {
            border-color: #eab308;
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 10px 30px rgba(168, 85, 247, 0.4), 0 0 15px rgba(234, 179, 8, 0.3);
            background: rgba(30, 15, 50, 0.8);
        }

        /* Live Peak Specific Button Styling */
        .live-btn {
            background: linear-gradient(135deg, rgba(30, 10, 50, 0.7) 0%, rgba(15, 5, 25, 0.8) 100%);
            border: 2px solid #eab308;
            box-shadow: 0 0 15px rgba(234, 179, 8, 0.25);
            animation: pulse-border 2s infinite alternate;
        }

        .live-btn:hover {
            box-shadow: 0 0 25px rgba(239, 68, 68, 0.5), 0 0 15px rgba(234, 179, 8, 0.5);
            border-color: #ef4444;
        }

        @keyframes pulse-border {
            0% {
                box-shadow: 0 0 12px rgba(234, 179, 8, 0.3);
            }
            100% {
                box-shadow: 0 0 25px rgba(234, 179, 8, 0.6);
            }
        }

        /* Scanning line overlay effect for cosmic game theme */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                rgba(18, 16, 16, 0) 50%, 
                rgba(0, 0, 0, 0.25) 50%
            );
            background-size: 100% 4px;
            z-index: 999;
            pointer-events: none;
            opacity: 0.15;
        }

        /* Smooth page particle system */
        .particle {
            position: absolute;
            border-radius: 50%;
            background: #eab308;
            animation: float-up 8s infinite linear;
            pointer-events: none;
            opacity: 0.25;
        }

        @keyframes float-up {
            0% {
                transform: translateY(105vh) translateX(0) scale(1);
            }
            100% {
                transform: translateY(-5vh) translateX(50px) scale(0.2);
            }
        }
    </style>
</head>
<body class="min-h-screen text-slate-100 relative flex flex-col justify-between">

    <!-- Vintage Cyber/Cosmic scanlines -->
    <div class="scanlines"></div>

    <!-- Background Floating Particles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="particle w-1.5 h-1.5" style="left: 10%; animation-delay: 0s; animation-duration: 12s;"></div>
        <div class="particle w-1 h-1" style="left: 25%; animation-delay: 2s; animation-duration: 15s;"></div>
        <div class="particle w-2 h-2" style="left: 45%; animation-delay: 4s; animation-duration: 18s;"></div>
        <div class="particle w-1.5 h-1.5" style="left: 70%; animation-delay: 1s; animation-duration: 14s;"></div>
        <div class="particle w-2.5 h-2.5" style="left: 85%; animation-delay: 5s; animation-duration: 20s;"></div>
    </div>

    <!-- Status Toast Notifications -->
    <div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col gap-3 pointer-events-none max-w-sm w-full"></div>

    <!-- Header brand section -->
    <header class="w-full text-center py-6 z-10 px-4">
        <div class="inline-block cursor-pointer" onclick="goHome()">
            <h1 class="font-orbitron text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-yellow-400 to-purple-500 hover:scale-105 transition-transform duration-300">
                CODE-REALME-NONSTOP
            </h1>
            <div class="h-1 w-full bg-gradient-to-r from-transparent via-yellow-500 to-transparent mt-3 rounded-full shadow-lg"></div>
            <p class="text-xs md:text-sm font-orbitron tracking-widest text-purple-300 mt-2 uppercase opacity-80">
                The Zenith of Infinite Dev-Realms
            </p>
        </div>
    </header>

    <!-- GATEWAY MODAL/VIEW (Profile Creation & Login) -->
    <section id="auth-gate" class="flex-grow flex items-center justify-center px-4 py-8 z-10">
        <div class="w-full max-w-3xl bg-purple-950/40 backdrop-blur-md rounded-2xl border-2 border-yellow-500/30 shadow-2xl p-6 md:p-8 neon-glow-purple">
            
            <!-- Dynamic Authentication Switch Tabs -->
            <div class="flex border-b border-purple-800/60 mb-8 font-orbitron text-sm md:text-base">
                <button id="tab-register" class="flex-1 text-center pb-3 text-yellow-400 border-b-2 border-yellow-400 font-bold transition-all" onclick="switchAuthTab('register')">
                    <i class="fa-solid fa-user-plus mr-2"></i>CREATE CODESIGNER PROFILE
                </button>
                <button id="tab-login" class="flex-1 text-center pb-3 text-purple-300/60 font-medium hover:text-purple-200 transition-all" onclick="switchAuthTab('login')">
                    <i class="fa-solid fa-right-to-bracket mr-2"></i>ACCESS ID DECK
                </button>
            </div>

            <!-- REGISTER FORM CONTAINER -->
            <div id="register-section" class="space-y-6">
                <div class="text-center md:text-left mb-4">
                    <h2 class="text-xl font-orbitron font-bold text-yellow-400">INITIALIZE NEW CODESIGN</h2>
                    <p class="text-xs text-purple-300/80 mt-1">Acquire unique access credentials inside the non-stop quantum storage ledger.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Left Inputs -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">CODESIGN NAME *</label>
                            <input type="text" id="reg-username" oninput="handleNameInput(this.value)" placeholder="e.g. NeoPrime" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all font-mono placeholder-purple-400/30 uppercase tracking-widest">
                            <span class="text-[10px] text-purple-400/60 mt-1 block">Your unique identification name. Alphabet code generated instantly.</span>
                        </div>
                        <div>
                            <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">SECURITY ACCESS PASSWORD *</label>
                            <input type="password" id="reg-password" placeholder="••••••••" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all font-mono">
                        </div>
                        <div>
                            <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">CODING LANGUAGES *</label>
                            <input type="text" id="reg-languages" placeholder="e.g. Rust, Python (Tip: include -Admin-access for override)" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all placeholder-purple-400/30 font-mono">
                            <span class="text-[10px] text-purple-400/60 mt-1 block">The programming tech stack you wield. Enter secret trigger here.</span>
                        </div>
                        <div>
                            <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">BIO / MOTTO</label>
                            <textarea id="reg-bio" rows="2" placeholder="e.g. Living in the cyber matrix, building decentralized realities." class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all text-sm placeholder-purple-400/30"></textarea>
                        </div>
                    </div>

                    <!-- Right Logo Picker & Dynamic Custom Preview -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-1 text-center md:text-left">CUSTOM LOGO (EMOJI OR PUBLIC IMAGE URL)</label>
                            <input type="text" id="reg-custom-logo" oninput="handleCustomLogo(this.value)" placeholder="⚡, 💻, or https://example.com/logo.png" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-2.5 text-xs text-white focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all placeholder-purple-400/30">
                        </div>

                        <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-1 text-center md:text-left">OR SELECT HOLO-AVATAR PRESET</label>
                        <div class="grid grid-cols-3 gap-3" id="avatar-grid">
                            <!-- Dynamically filled with ultra-cool avatars -->
                        </div>

                        <!-- Interactive live preview card -->
                        <div class="bg-purple-950/60 border border-yellow-500/30 rounded-xl p-3 flex items-center gap-3">
                            <div id="live-logo-preview-container" class="w-12 h-12 rounded-full bg-gradient-to-br from-yellow-500 to-amber-600 flex items-center justify-center text-xl font-bold font-orbitron text-purple-950 shadow-md">
                                <span id="live-logo-text">?</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-orbitron text-yellow-400 tracking-wider">REALTIME PROFILE PREVIEW</span>
                                <div id="live-preview-name" class="font-bold text-sm text-white font-mono uppercase tracking-widest">Awaiting Name...</div>
                                <div id="live-preview-logo-type" class="text-[9.5px] text-purple-300">Preset: Alphabet Initial</div>
                            </div>
                        </div>

                        <input type="hidden" id="selected-avatar" value="">
                        <input type="hidden" id="selected-avatar-color" value="from-yellow-500 to-amber-600">
                    </div>
                </div>

                <!-- Registration Actions -->
                <div class="pt-4 border-t border-purple-900/60 flex flex-col sm:flex-row items-center justify-between gap-4">
                    <span class="text-xs text-yellow-400/60 font-mono"><i class="fa-solid fa-server mr-1.5"></i>PERSISTENT PERSISTENCE: ONLINE</span>
                    <button onclick="registerProfile()" class="w-full sm:w-auto px-8 py-3 bg-gradient-to-r from-yellow-500 to-amber-600 text-purple-950 font-orbitron font-bold rounded-lg hover:shadow-lg hover:shadow-yellow-500/20 active:scale-95 transition-all tracking-wider text-sm flex items-center justify-center gap-2">
                        <i class="fa-solid fa-rocket animate-pulse"></i> SPARK COGNITION
                    </button>
                </div>
            </div>

            <!-- LOGIN FORM CONTAINER -->
            <div id="login-section" class="space-y-6 hidden">
                <div class="text-center md:text-left mb-4">
                    <h2 class="text-xl font-orbitron font-bold text-yellow-400">RESTORE SYSTEM ACCESS</h2>
                    <p class="text-xs text-purple-300/80 mt-1">Re-authenticate code sign key to load down personal user credentials.</p>
                </div>

                <div class="max-w-md mx-auto space-y-4 py-4">
                    <div>
                        <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">CODESIGN NAME</label>
                        <input type="text" id="login-username" placeholder="ENTER YOUR UNIQUE CODESIGN" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white text-center focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all font-mono placeholder-purple-400/30 uppercase tracking-widest text-lg">
                    </div>
                    <div>
                        <label class="block text-xs font-orbitron text-purple-300 tracking-wider mb-2">SECURITY PASSWORD</label>
                        <input type="password" id="login-password" placeholder="••••••••" class="w-full bg-purple-900/30 border border-purple-500/30 rounded-lg p-3 text-white text-center focus:outline-none focus:ring-2 focus:ring-yellow-400 transition-all font-mono text-lg">
                    </div>
                </div>

                <!-- Login Actions -->
                <div class="pt-4 border-t border-purple-900/60 flex flex-col sm:flex-row items-center justify-between gap-4">
                    <span class="text-xs text-purple-400/50 font-mono"><i class="fa-solid fa-network-wired mr-1.5"></i>Secure Session Syncing</span>
                    <button onclick="loginProfile()" class="w-full sm:w-auto px-8 py-3 bg-gradient-to-r from-purple-600 to-indigo-700 text-white font-orbitron font-bold rounded-lg hover:shadow-lg hover:shadow-purple-500/30 active:scale-95 transition-all tracking-wider text-sm flex items-center justify-center gap-2">
                        <i class="fa-solid fa-unlock-keyhole"></i> ENGAGE DECK
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- MAIN CENTRAL DASHBOARD (Hidden until authorization complete) -->
    <main id="main-dashboard" class="hidden flex-grow flex flex-col items-center justify-center px-4 md:px-8 py-6 z-10 w-full">
        
        <!-- Welcome banner/active pilot tag -->
        <div id="dashboard-banner" class="max-w-6xl w-full mb-8 flex flex-col sm:flex-row items-center justify-between gap-4 bg-purple-950/25 border border-purple-800/30 rounded-xl p-4 backdrop-blur-md transition-all duration-500">
            <div class="flex items-center gap-4">
                <!-- User logo icon display -->
                <div id="active-user-avatar-container" class="w-14 h-14 rounded-full bg-gradient-to-br flex items-center justify-center border border-yellow-400/40 shadow-lg shadow-purple-500/15 text-2xl overflow-hidden">
                    <span id="active-user-avatar-icon">👻</span>
                </div>
                <div>
                    <div class="flex items-center gap-2">
                        <span id="active-system-badge" class="text-[10px] font-orbitron text-yellow-400 tracking-widest uppercase">CODESIGNER CONNECTED</span>
                        <span id="admin-indicator-badge" class="hidden text-[9px] font-mono font-bold bg-red-600 text-white px-2 py-0.5 rounded animate-pulse">OVERLORD ACCESS</span>
                    </div>
                    <h3 id="active-user-name" class="font-orbitron font-bold text-lg text-white">Guest Operator</h3>
                    <p id="active-user-languages" class="text-xs text-purple-300 font-mono">Languages: Rust, Python</p>
                    <p id="active-user-bio" class="text-xs text-purple-400/90 italic mt-1 line-clamp-1">No bio loaded.</p>
                </div>
            </div>

            <!-- Terminal indicators -->
            <div class="flex items-center gap-3">
                <span class="text-[10px] font-mono text-purple-400 bg-purple-900/30 border border-purple-700/40 px-2.5 py-1 rounded">
                    SYS: <span id="sys-status-text" class="text-emerald-400 animate-pulse">ONLINE</span>
                </span>
                <span id="active-user-tag" class="text-[10px] font-mono text-yellow-400 bg-yellow-950/30 border border-yellow-700/40 px-2.5 py-1 rounded uppercase">
                    ID: NONE
                </span>
                <button onclick="logOut()" class="px-3 py-1 bg-red-950/40 hover:bg-red-900/60 border border-red-500/30 hover:border-red-500 text-red-400 rounded text-xs font-orbitron transition-all">
                    DECOUPLE
                </button>
            </div>
        </div>

        <!-- SECURE ADMIN MODULE (Visible only if Admin account detected) -->
        <div id="admin-only-console" class="hidden max-w-6xl w-full mb-8 bg-black/80 border-2 border-red-500 rounded-xl p-5 shadow-2xl space-y-4">
            <div class="flex items-center justify-between border-b border-red-900/50 pb-2">
                <h4 class="font-orbitron font-bold text-red-500 text-sm tracking-widest flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-ping"></span>
                    HYPER-CORE SYSTEM MANAGEMENT [ADMIN OVERFLOW ACTIVE]
                </h4>
                <span class="text-[9px] font-mono text-red-400/80 uppercase">Node-Id: non-stop-quantum-overload</span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-red-950/20 border border-red-500/30 p-3 rounded-lg text-xs space-y-2">
                    <div class="font-orbitron font-bold text-yellow-400">CORE BYPASS LOGS</div>
                    <div class="font-mono text-[10px] text-red-300 space-y-1 h-24 overflow-y-auto" id="admin-log-box">
                        <div>&gt; System Overlord authorization bypass: OK</div>
                        <div>&gt; Mainframe database linked...</div>
                        <div>&gt; Overriding default protocol constraints...</div>
                    </div>
                </div>

                <div class="bg-red-950/20 border border-red-500/30 p-3 rounded-lg text-xs space-y-2 flex flex-col justify-between">
                    <div>
                        <div class="font-orbitron font-bold text-yellow-400 mb-1">REALM LEVEL DIAGNOSTICS</div>
                        <p class="text-[11px] text-purple-300">Simulate server adjustments, push system patches, or dispatch immediate hotfixes across global layers.</p>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="simulateAdminAction('SYS_OVERLOAD')" class="flex-1 py-1.5 bg-red-600 hover:bg-red-500 text-white font-orbitron font-bold rounded text-[10px] transition-all uppercase">Overload Core</button>
                        <button onclick="simulateAdminAction('SYS_CLEAN')" class="flex-1 py-1.5 bg-yellow-500 hover:bg-yellow-400 text-purple-950 font-orbitron font-bold rounded text-[10px] transition-all uppercase">Flush Memory</button>
                    </div>
                </div>

                <div class="bg-red-950/20 border border-red-500/30 p-3 rounded-lg text-xs space-y-2">
                    <div class="font-orbitron font-bold text-yellow-400">ADMINISTRATIVE BROADCAST</div>
                    <input type="text" id="admin-broadcast-msg" placeholder="Broadcast notification to client terminals..." class="w-full bg-black border border-red-500/40 rounded p-1.5 text-[11px] text-red-200 placeholder-red-900 focus:outline-none focus:border-red-400 font-mono">
                    <button onclick="sendAdminBroadcast()" class="w-full py-1 bg-gradient-to-r from-red-600 to-yellow-600 text-white font-orbitron font-bold text-[10.5px] rounded tracking-widest hover:brightness-110 active:scale-95 transition-all">
                        DISPATCH BROADCAST
                    </button>
                </div>
            </div>
        </div>

        <!-- Central Grid Container -->
        <div class="max-w-6xl w-full">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

                <!-- 1. TEAMS -->
                <button onclick="openFeature('TEAMS', 'Initiate alliances, build cosmic battle groups, and explore global software guilds.')" class="btn-card p-6 rounded-2xl flex flex-col items-center justify-center text-center group">
                    <div class="w-16 h-16 rounded-full bg-purple-900/40 flex items-center justify-center border border-purple-500/30 group-hover:border-yellow-400/50 transition-colors mb-4 shadow-inner">
                        <i class="fa-solid fa-users text-2xl text-purple-400 group-hover:text-yellow-400 transition-colors"></i>
                    </div>
                    <span class="font-orbitron font-bold text-lg tracking-wider text-purple-200 group-hover:text-yellow-400 transition-colors">
                        TEAMS
                    </span>
                    <span class="text-xs text-purple-400/60 mt-1 uppercase tracking-widest font-medium">Alliance Portal</span>
                </button>

                <!-- 2. PROJECTS-STAG DESIGN -->
                <button onclick="openFeature('PROJECTS-STAG DESIGN', 'View active blueprints, stage cloud servers, and edit collaborative structural elements.')" class="btn-card p-6 rounded-2xl flex flex-col items-center justify-center text-center group">
                    <div class="w-16 h-16 rounded-full bg-purple-900/40 flex items-center justify-center border border-purple-500/30 group-hover:border-yellow-400/50 transition-colors mb-4 shadow-inner">
                        <i class="fa-solid fa-compass-drafting text-2xl text-purple-400 group-hover:text-yellow-400 transition-colors"></i>
                    </div>
                    <span class="font-orbitron font-bold text-lg tracking-wider text-purple-200 group-hover:text-yellow-400 transition-colors">
                        PROJECTS-STAG DESIGN
                    </span>
                    <span class="text-xs text-purple-400/60 mt-1 uppercase tracking-widest font-medium">Architecture & Blueprints</span>
                </button>

                <!-- 3. QUESTS -->
                <button onclick="openFeature('QUESTS', 'Accept algorithm quests, resolve system vulnerabilities, and gain galactic experience points (XP).')" class="btn-card p-6 rounded-2xl flex flex-col items-center justify-center text-center group">
                    <div class="w-16 h-16 rounded-full bg-purple-900/40 flex items-center justify-center border border-purple-500/30 group-hover:border-yellow-400/50 transition-colors mb-4 shadow-inner">
                        <i class="fa-solid fa-shield-halved text-2xl text-purple-400 group-hover:text-yellow-400 transition-colors"></i>
                    </div>
                    <span class="font-orbitron font-bold text-lg tracking-wider text-purple-200 group-hover:text-yellow-400 transition-colors">
                        QUESTS
                    </span>
                    <span class="text-xs text-purple-400/60 mt-1 uppercase tracking-widest font-medium">Challenges & XP</span>
                </button>

                <!-- 4. PROFILE (Dynamic view options) -->
                <button onclick="openFeature('YOUR REALM PROFILE', 'Displaying loaded data ledger... Change languages and sync directly with Firestore database.', true)" class="btn-card p-6 rounded-2xl flex flex-col items-center justify-center text-center group">
                    <div class="w-16 h-16 rounded-full bg-purple-900/40 flex items-center justify-center border border-purple-500/30 group-hover:border-yellow-400/50 transition-colors mb-4 shadow-inner">
                        <i class="fa-solid fa-user-gear text-2xl text-purple-400 group-hover:text-yellow-400 transition-colors"></i>
                    </div>
                    <span class="font-orbitron font-bold text-lg tracking-wider text-purple-200 group-hover:text-yellow-400 transition-colors">
                        PROFILE
                    </span>
                    <span class="text-xs text-purple-400/60 mt-1 uppercase tracking-widest font-medium">Identity & Badges</span>
                </button>

                <!-- 5. JOIN THE REALMES -->
                <button onclick="openFeature('JOIN THE REALMES', 'Request integration into primary command protocols, cosmic hubs, and private dev bunkers.')" class="btn-card p-6 rounded-2xl flex flex-col items-center justify-center text-center group">
                    <div class="w-16 h-16 rounded-full bg-purple-900/40 flex items-center justify-center border border-purple-500/30 group-hover:border-yellow-400/50 transition-colors mb-4 shadow-inner">
                        <i class="fa-solid fa-dungeon text-2xl text-purple-400 group-hover:text-yellow-400 transition-colors"></i>
                    </div>
                    <span class="font-orbitron font-bold text-lg tracking-wider text-purple-200 group-hover:text-yellow-400 transition-colors text-center">
                        JOIN THE REALMES
                    </span>
                    <span class="text-xs text-purple-400/60 mt-1 uppercase tracking-widest font-medium">Initiate Sanctuary</span>
