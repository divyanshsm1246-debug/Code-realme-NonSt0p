    <!-- FIREBASE AND CLIENT logic -->
    <script type="module">
        // Import the necessary modules safely from CDN
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, getDoc, setDoc, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Global state handling
        let app, db, auth;
        let activeProfile = null;

        // Custom built-in cool avatars
        const AVAILABLE_AVATARS = [
            { icon: "👻", colors: "from-purple-500 to-indigo-600", desc: "Ghost" },
            { icon: "🐵👓", colors: "from-amber-500 to-red-600", desc: "Cool Monkey" },
            { icon: "🐱‍💻", colors: "from-emerald-500 to-teal-600", desc: "Cyber Cat" },
            { icon: "🧙‍♂️", colors: "from-pink-500 to-rose-600", desc: "Wizard" },
            { icon: "👽", colors: "from-blue-500 to-cyan-600", desc: "Alien" },
            { icon: "🤖", colors: "from-zinc-700 to-slate-900", desc: "Mech" }
        ];

        // Global variables initialized or configured
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'code-realme-nonstop';
        const defaultFirebaseConfig = {
            apiKey: "dummy-key-for-local-preview",
            authDomain: "dummy.firebaseapp.com",
            projectId: "dummy-project",
            storageBucket: "dummy.appspot.com",
            messagingSenderId: "123456",
            appId: "1:1234:web:abcd"
        };
        const firebaseConfig = typeof __firebase_config !== 'undefined' 
            ? JSON.parse(__firebase_config) 
            : defaultFirebaseConfig;

        // Initialize Firebase with fallback logs
        try {
            app = initializeApp(firebaseConfig);
            db = getFirestore(app);
            auth = getAuth(app);
            console.log("Database & Security System Initialized successfully.");
        } catch (err) {
            console.error("Firebase Initialization Error:", err);
            showToast("Database system is running in offline sandbox.", "warning");
        }

        // Handle typing username -> Dynamic first alphabet logo generator
        window.handleNameInput = function(nameVal) {
            const previewName = document.getElementById("live-preview-name");
            const previewLogoText = document.getElementById("live-logo-text");
            const customLogoVal = document.getElementById("reg-custom-logo").value.trim();

            if (!nameVal.trim()) {
                previewName.textContent = "Awaiting Name...";
                if (!customLogoVal) {
                    previewLogoText.innerHTML = "?";
                }
                return;
            }

            previewName.textContent = nameVal;

            // Only update preview with initials if no custom logo is entered
            if (!customLogoVal) {
                const firstLetter = nameVal.trim().charAt(0).toUpperCase();
                previewLogoText.innerHTML = firstLetter;
                document.getElementById("selected-avatar").value = firstLetter;
                document.getElementById("live-preview-logo-type").textContent = "Dynamic Name Initial";
            }
        };

        // Handle typing custom logo
        window.handleCustomLogo = function(logoVal) {
            const previewLogoText = document.getElementById("live-logo-text");
            const previewType = document.getElementById("live-preview-logo-type");

            if (!logoVal.trim()) {
                // Fallback to name initial
                const nameVal = document.getElementById("reg-username").value.trim();
                if (nameVal) {
                    const firstLetter = nameVal.charAt(0).toUpperCase();
                    previewLogoText.innerHTML = firstLetter;
                    document.getElementById("selected-avatar").value = firstLetter;
                    previewType.textContent = "Dynamic Name Initial";
                } else {
                    previewLogoText.innerHTML = "?";
                    document.getElementById("selected-avatar").value = "";
                    previewType.textContent = "Awaiting preset/customization...";
                }
                return;
            }

            // Check if logoVal is image URL
            if (logoVal.startsWith("http://") || logoVal.startsWith("https://")) {
                previewLogoText.innerHTML = `<img src="${logoVal}" class="w-full h-full object-cover rounded-full" onerror="this.onerror=null; this.parentElement.innerHTML='⚠️'">`;
                previewType.textContent = "Custom Image Web URL";
            } else {
                previewLogoText.innerHTML = logoVal;
                previewType.textContent = "Custom Emoji/Text Symbol";
            }

            document.getElementById("selected-avatar").value = logoVal;
        };

        // Render Avatar select grid
        function renderAvatars() {
            const grid = document.getElementById("avatar-grid");
            if (!grid) return;
            grid.innerHTML = "";

            AVAILABLE_AVATARS.forEach((av, index) => {
                const div = document.createElement("button");
                div.type = "button";
                div.className = `avatar-btn flex flex-col items-center justify-center p-2 rounded-xl border-2 border-purple-800/40 bg-purple-950/20 hover:border-purple-500/40 transition-all duration-300`;
                div.onclick = () => selectPresetAvatar(index, div);

                div.innerHTML = `
                    <div class="w-9 h-9 rounded-full bg-gradient-to-br ${av.colors} flex items-center justify-center shadow-inner mb-0.5 text-lg">
                        <span>${av.icon}</span>
                    </div>
                    <span class="text-[8px] font-orbitron tracking-widest text-purple-300 uppercase">${av.desc}</span>
                `;
                grid.appendChild(div);
            });
        }

        function selectPresetAvatar(index, el) {
            // Reset visual buttons
            document.querySelectorAll(".avatar-btn").forEach(btn => {
                btn.classList.remove("border-yellow-400", "bg-purple-900/50", "shadow-md", "shadow-yellow-500/10");
                btn.classList.add("border-purple-800/40", "bg-purple-950/20");
            });

            // Set active selection
            el.classList.add("border-yellow-400", "bg-purple-900/50", "shadow-md", "shadow-yellow-500/10");
            el.classList.remove("border-purple-800/40", "bg-purple-950/20");

            const avatar = AVAILABLE_AVATARS[index];
            document.getElementById("reg-custom-logo").value = ""; // Clear custom text override
            document.getElementById("selected-avatar").value = avatar.icon;
            document.getElementById("selected-avatar-color").value = avatar.colors;

            // Update live card preview
            const previewLogoText = document.getElementById("live-logo-text");
            previewLogoText.innerHTML = avatar.icon;
            document.getElementById("live-preview-logo-type").textContent = `Preset: ${avatar.desc}`;

            const container = document.getElementById("live-logo-preview-container");
            container.className = `w-12 h-12 rounded-full bg-gradient-to-br ${avatar.colors} flex items-center justify-center text-xl font-bold font-orbitron shadow-md`;
        }

        // Authenticate anonymously (or custom token if provided) as per rules
        async function authenticateUser() {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch (err) {
                console.error("Authentication handshake failed:", err);
            }
        }

        // Register Profile in Firestore (RULE 1 Strict Path: /artifacts/{appId}/public/data/profiles/{username})
        async function registerProfile() {
            const rawUsername = document.getElementById("reg-username").value.trim();
            const password = document.getElementById("reg-password").value.trim();
            const languages = document.getElementById("reg-languages").value.trim();
            const bio = document.getElementById("reg-bio").value.trim();
            let avatarIcon = document.getElementById("selected-avatar").value.trim();
            const avatarColor = document.getElementById("selected-avatar-color").value;

            if (!rawUsername || !password || !languages) {
                showToast("Please complete all profile details and choose a password.", "error");
                return;
            }

            // Standardize username to uppercase/no-spaces
            const username = rawUsername.replace(/[^a-zA-Z0-9]/g, "").toUpperCase();
            if (!username) {
                showToast("Invalid username symbols. Use alphanumeric.", "error");
                return;
            }

            // If no custom or preset avatar selected, use first alphabet of user's name
            if (!avatarIcon) {
                avatarIcon = username.charAt(0);
            }

            // Detect Secret Admin Access Code
            const isAdmin = languages.toLowerCase().includes("-admin-access");

            // Auth guard
            await authenticateUser();
            const user = auth.currentUser;
            if (!user) {
                showToast("Identity verification currently offline.", "error");
                return;
            }

            try {
                // Rule 1: Public data path
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'profiles', username);
                const docSnap = await getDoc(docRef);

                if (docSnap.exists()) {
                    showToast("Codesigner Name is already claimed! Choose another.", "error");
                    return;
                }

                const profileData = {
                    username: username,
                    password: password, 
                    languages: languages,
                    bio: bio || "A silent developer navigating the digital cosmos.",
                    avatarIcon: avatarIcon,
                    avatarColor: avatarColor,
                    isAdmin: isAdmin,
                    ownerUid: user.uid,
                    createdTimestamp: Date.now()
                };

                // Store in Firestore
                await setDoc(docRef, profileData);
                
                if (isAdmin) {
                    showToast("SYSTEM OVERLORD ACCESS DETECTED & SAVED!", "success");
                } else {
                    showToast("Codesigner profile recorded permanently!", "success");
                }
                
                // Complete login with created profile
                activeProfile = profileData;
                loadDashboardUI();

            } catch (err) {
                console.error("Firestore database write error:", err);
                showToast("Database sync error. Local fallback active.", "warning");
                // Local memory fallback
                activeProfile = { username, password, languages, bio, avatarIcon, avatarColor, isAdmin };
                loadDashboardUI();
            }
        }

        // Login Profile with existing Username and Password verification
        async function loginProfile() {
            const rawUsername = document.getElementById("login-username").value.trim();
            const password = document.getElementById("login-password").value.trim();
            
            if (!rawUsername || !password) {
                showToast("Please enter Username and Password.", "error");
                return;
            }

            const username = rawUsername.replace(/[^a-zA-Z0-9]/g, "").toUpperCase();

            // Authenticate first
            await authenticateUser();
            const user = auth.currentUser;
            if (!user) {
                showToast("Auth gateway unresponsive.", "error");
                return;
            }

            try {
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'profiles', username);
                const docSnap = await getDoc(docRef);

                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (data.password === password) {
                        activeProfile = data;
                        showToast("Codesigner deck unlocked successfully!", "success");
                        loadDashboardUI();
                    } else {
                        showToast("Access Denied: Incorrect Security Password.", "error");
                    }
                } else {
                    showToast("No database profile matched this key.", "error");
                }
            } catch (err) {
                console.error("Firestore read error:", err);
                showToast("Local profile access failed.", "error");
            }
        }

        // Complete edit sync for all profile parameters (Languages, Bio, Logo/Avatar)
        async function updateProfileComplete() {
            if (!activeProfile) return;
            const newLanguages = document.getElementById("update-languages-input").value.trim();
            const newBio = document.getElementById("update-bio-input").value.trim();
            const newLogo = document.getElementById("update-logo-input").value.trim();

            if (!newLanguages) {
                showToast("Languages cannot be empty.", "error");
                return;
            }

            // Look for new admin access requests
            const isAdmin = newLanguages.toLowerCase().includes("-admin-access");

            await authenticateUser();
            if (!auth.currentUser) return;

            try {
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'profiles', activeProfile.username);
                
                const updatedPayload = { 
                    languages: newLanguages,
                    bio: newBio || "A silent developer navigating the digital cosmos.",
                    isAdmin: isAdmin
                };

                // If logo input has changed, update it as well
                if (newLogo) {
                    updatedPayload.avatarIcon = newLogo;
                }

                await updateDoc(docRef, updatedPayload);
                
                // Sync local memory and UI
                activeProfile.languages = newLanguages;
                activeProfile.bio = updatedPayload.bio;
                activeProfile.isAdmin = isAdmin;
                if (newLogo) {
                    activeProfile.avatarIcon = newLogo;
                }
                
                loadDashboardUI();
                showToast("Profile changes synced with Database!", "success");
                closeModal();
            } catch (err) {
                console.error("Failed to update profile parameters:", err);
                showToast("Database update offline.", "error");
            }
        }

        // Screen toggle & layout management
        function loadDashboardUI() {
            if (!activeProfile) return;

            // Transition gates
            document.getElementById("auth-gate").classList.add("hidden");
            document.getElementById("main-dashboard").classList.remove("hidden");

            // Populate dashboard user indicators
            document.getElementById("active-user-name").textContent = activeProfile.username;
            document.getElementById("active-user-languages").textContent = `Languages: ${activeProfile.languages}`;
            document.getElementById("active-user-tag").textContent = `ID: ${activeProfile.username}`;
            document.getElementById("active-user-bio").textContent = activeProfile.bio;

            // Parse Logo - URL or emoji/initial
            const activeLogoIcon = document.getElementById("active-user-avatar-icon");
            if (activeProfile.avatarIcon.startsWith("http://") || activeProfile.avatarIcon.startsWith("https://")) {
                activeLogoIcon.innerHTML = `<img src="${activeProfile.avatarIcon}" class="w-full h-full object-cover rounded-full">`;
            } else {
                activeLogoIcon.innerHTML = activeProfile.avatarIcon;
            }

            // Handle user visual avatar colors
            const container = document.getElementById("active-user-avatar-container");
            const avatarColorClass = activeProfile.avatarColor || "from-purple-500 to-indigo-600";
            container.className = `w-14 h-14 rounded-full bg-gradient-to-br ${avatarColorClass} flex items-center justify-center border border-yellow-400/40 shadow-lg shadow-purple-500/15 text-2xl overflow-hidden`;

            // Preset values in profile updater modal inputs
            document.getElementById("update-languages-input").value = activeProfile.languages;
            document.getElementById("update-bio-input").value = activeProfile.bio;
            document.getElementById("update-logo-input").value = activeProfile.avatarIcon.startsWith("http") ? activeProfile.avatarIcon : "";

            // Admin Module Activation
            const banner = document.getElementById("dashboard-banner");
            const adminModule = document.getElementById("admin-only-console");
            const badge = document.getElementById("admin-indicator-badge");
            const systemText = document.getElementById("active-system-badge");
            const sysStatus = document.getElementById("sys-status-text");

            if (activeProfile.isAdmin) {
                banner.classList.add("admin-glow");
                adminModule.classList.remove("hidden");
                badge.classList.remove("hidden");
                systemText.textContent = "SYSTEM OVERLORD COMMANDER";
                systemText.className = "text-[10px] font-orbitron tracking-widest admin-text-pulse font-bold";
                sysStatus.textContent = "OVERLORD SECURE ACTIVE";
                sysStatus.className = "text-red-500 font-bold animate-pulse";
                addAdminLog("Mainframe console acquired. Welcome Back Admin.");
            } else {
                banner.classList.remove("admin-glow");
                adminModule.classList.add("hidden");
                badge.classList.add("hidden");
                systemText.textContent = "CODESIGNER CONNECTED";
                systemText.className = "text-[10px] font-orbitron text-yellow-400 tracking-widest uppercase";
                sysStatus.textContent = "ONLINE";
                sysStatus.className = "text-emerald-400 animate-pulse";
            }
        }

        // Live admin action simulator
        window.simulateAdminAction = function(actionType) {
            const logBox = document.getElementById("admin-log-box");
            if (actionType === 'SYS_OVERLOAD') {
                showToast("WARNING: CORE TEMPERATURE CRITICAL. POWER REDISTRIBUTED!", "warning");
                addAdminLog("CRITICAL: Manual overload sequence initiated...");
                addAdminLog("WARNING: Reactor heat level peaking at 112%...");
                addAdminLog("INFO: Safeguard overrides accepted by Overlord authority.");
            } else if (actionType === 'SYS_CLEAN') {
                showToast("System database buffer cache purged.", "success");
                addAdminLog("STATUS: Initiating cache sweep...");
                addAdminLog("STATUS: Purged 1,402 orphaned connection packets...");
                addAdminLog("SUCCESS: Memory buffer alignment optimized.");
            }
        };

        window.sendAdminBroadcast = function() {
            const input = document.getElementById("admin-broadcast-msg");
            if (!input.value.trim()) return;

            showToast(`Broadcast Dispatched: "${input.value}"`, "success");
            addAdminLog(`BROADCAST: Sent payload [${input.value}]`);
            input.value = "";
        };

        function addAdminLog(msg) {
            const logBox = document.getElementById("admin-log-box");
            if (!logBox) return;
            const d = new Date();
            const timeStr = d.toTimeString().split(' ')[0];
            logBox.innerHTML += `<div>[${timeStr}] &gt; ${msg}</div>`;
            logBox.scrollTop = logBox.scrollHeight;
        }

        function logOut() {
            activeProfile = null;
            document.getElementById("auth-gate").classList.remove("hidden");
            document.getElementById("main-dashboard").classList.add("hidden");
            document.getElementById("admin-only-console").classList.add("hidden");
            document.getElementById("login-username").value = "";
            document.getElementById("login-password").value = "";
            
            // Clear inputs
            document.getElementById("reg-username").value = "";
            document.getElementById("reg-password").value = "";
            document.getElementById("reg-languages").value = "";
            document.getElementById("reg-bio").value = "";
            document.getElementById("reg-custom-logo").value = "";
            document.getElementById("selected-avatar").value = "";
            document.getElementById("live-logo-text").textContent = "?";
            document.getElementById("live-preview-name").textContent = "Awaiting Name...";
            
            showToast("Session security keys wiped.", "warning");
        }

        // Global interface connectors
        window.registerProfile = registerProfile;
        window.loginProfile = loginProfile;
        window.logOut = logOut;
        window.updateProfileComplete = updateProfileComplete;

        window.switchAuthTab = function(tab) {
            const regTab = document.getElementById("tab-register");
            const logTab = document.getElementById("tab-login");
            const regSect = document.getElementById("register-section");
            const logSect = document.getElementById("login-section");

            if (tab === 'register') {
                regTab.className = "flex-1 text-center pb-3 text-yellow-400 border-b-2 border-yellow-400 font-bold transition-all";
                logTab.className = "flex-1 text-center pb-3 text-purple-300/60 font-medium hover:text-purple-200 transition-all";
                regSect.classList.remove("hidden");
                logSect.classList.add("hidden");
            } else {
                logTab.className = "flex-1 text-center pb-3 text-yellow-400 border-b-2 border-yellow-400 font-bold transition-all";
                regTab.className = "flex-1 text-center pb-3 text-purple-300/60 font-medium hover:text-purple-200 transition-all";
                logSect.classList.remove("hidden");
                regSect.classList.add("hidden");
            }
        };

        window.goHome = function() {
            if (activeProfile) {
                loadDashboardUI();
            }
        };

        // Modal triggers
        window.openFeature = function(title, desc, isProfile = false) {
            const modal = document.getElementById("feature-modal");
            const containerBox = document.getElementById("modal-container-box");
            document.getElementById("modal-title").innerText = title;
            document.getElementById("modal-description").innerText = desc;

            // Adapt modal boundary based on admin status
            if (activeProfile && activeProfile.isAdmin) {
                containerBox.classList.add("border-red-500");
                containerBox.classList.remove("border-yellow-500/40");
            } else {
                containerBox.classList.remove("border-red-500");
                containerBox.classList.add("border-yellow-500/40");
            }

            const profileExtra = document.getElementById("modal-profile-extra");
            if (isProfile && activeProfile) {
                profileExtra.classList.remove("hidden");
                
                // Fill details inside the visual modal
                const mpAvatarDiv = document.getElementById("mp-avatar-div");
                const mpAvatarIcon = document.getElementById("mp-avatar-icon");
                
                // Parse image URL or text icon
                if (activeProfile.avatarIcon.startsWith("http://") || activeProfile.avatarIcon.startsWith("https://")) {
                    mpAvatarIcon.innerHTML = `<img src="${activeProfile.avatarIcon}" class="w-full h-full object-cover rounded-full">`;
                } else {
                    mpAvatarIcon.innerHTML = activeProfile.avatarIcon;
                }

                const avatarColorClass = activeProfile.avatarColor || "from-purple-500 to-indigo-600";
                mpAvatarDiv.className = `w-14 h-14 rounded-full flex items-center justify-center border-2 border-yellow-400 bg-gradient-to-br ${avatarColorClass} text-3xl overflow-hidden`;
                
                document.getElementById("mp-displayname").textContent = activeProfile.username;
                document.getElementById("mp-languages").textContent = `Languages: ${activeProfile.languages}`;
                document.getElementById("mp-key").textContent = activeProfile.username;
                document.getElementById("mp-bio-preview").textContent = activeProfile.bio;

                const roleType = document.getElementById("mp-role-type");
                if (activeProfile.isAdmin) {
                    roleType.textContent = "SYSTEM OVERLORD ADMIN";
                    roleType.className = "text-red-500 font-bold";
                } else {
                    roleType.textContent = "STANDARD CODESIGNER";
                    roleType.className = "text-emerald-400";
                }
            } else {
                profileExtra.classList.add("hidden");
            }

            modal.classList.remove("hidden");
        };

        window.closeModal = function() {
            document.getElementById("feature-modal").classList.add("hidden");
        };

        // Toast notifications
        window.showToast = function(message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            
            let bgClass = "bg-emerald-950/95 border-emerald-500 text-emerald-300";
            let iconClass = "fa-circle-check text-emerald-400";
            
            if (type === "error") {
                bgClass = "bg-red-950/95 border-red-500 text-red-300";
                iconClass = "fa-circle-exclamation text-red-400";
            } else if (type === "warning") {
                bgClass = "bg-amber-950/95 border-amber-500 text-amber-300";
                iconClass = "fa-triangle-exclamation text-amber-400";
            }

            toast.className = `flex items-center gap-3 p-4 rounded-xl border backdrop-blur-md shadow-2xl transition-all duration-300 transform translate-x-12 opacity-0 pointer-events-auto ${bgClass}`;
            toast.innerHTML = `
                <i class="fa-solid ${iconClass} text-lg"></i>
                <div class="flex-1 text-xs font-semibold font-orbitron tracking-wider">${message}</div>
                <button onclick="this.parentElement.remove()" class="text-xs hover:text-white transition-all"><i class="fa-solid fa-xmark"></i></button>
            `;

            container.appendChild(toast);
            
            // Animate In
            setTimeout(() => {
                toast.classList.remove("translate-x-12", "opacity-0");
            }, 10);

            // Animate Out
            setTimeout(() => {
                toast.classList.add("translate-x-12", "opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        };

        // Run setup on load
        window.onload = function() {
            renderAvatars();
        }
    </script>
</body>
</html>
